# Copy to .env and fill in real values (do NOT commit .env).

# Devin API key (Service User API Key or PAT, "cog_" prefix).
DEVIN_API_KEY=cog_REPLACE_ME_WITH_YOUR_DEVIN_API_KEY

# Base URL for the Devin API (rarely needs changing).
DEVIN_API_BASE_URL=https://api.devin.ai

# The repository the triggered Devin session should upgrade.
TARGET_REPO_URL=https://github.com/your-org/your-repo

# Shared secret configured on the GitHub webhook (used to verify signatures).
GITHUB_WEBHOOK_SECRET=

# Issue label that triggers a session.
TRIGGER_LABEL=dependency_upgrade

# Optional ACU cap for triggered sessions (leave blank for no limit).
DEVIN_MAX_ACU_LIMIT=
